model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  password String
  status   UserStatus @default(ACTIVE)
  role     UserRole   @default(TENANT)
  profilePhoto String?
  bio          String?
  
  properties     Property[]
  rentalRequests RentalRequest[]
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
